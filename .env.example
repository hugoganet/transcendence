# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (local dev)
DATABASE_URL=postgresql://transcendence:transcendence@localhost:5432/transcendence?schema=public
DATABASE_URL_TEST=postgresql://postgres:postgres@127.0.0.1:54322/transcendence_test
DATABASE_POOL_SIZE=10

# Database (Docker — used by docker-compose)
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=transcendence
POSTGRES_DB=transcendence
# In Docker, DATABASE_URL becomes: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public

# Redis
REDIS_URL=redis://localhost:6379
# In Docker, REDIS_URL becomes: redis://redis:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Session
SESSION_SECRET=change-me-in-production
SESSION_TTL_SECONDS=1800

# Two-Factor Authentication (optional — 2FA won't work without this)
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# OAuth Token Encryption (optional — OAuth tokens won't be encrypted at rest without this)
# Generate with: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=

# OAuth (optional — app works without these)
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook OAuth: https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Base URL for OAuth callbacks (no trailing slash)
# Callback URLs: ${OAUTH_CALLBACK_BASE_URL}/api/v1/auth/google/callback
#                ${OAUTH_CALLBACK_BASE_URL}/api/v1/auth/facebook/callback
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# Email (optional — app works without these, but password reset emails won't send)
# Resend: https://resend.com/api-keys
RESEND_API_KEY=
# Sender address (must be verified in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Avatar Upload
# Directory where avatar images are stored (default: ./uploads/avatars)
AVATAR_UPLOAD_DIR=./uploads/avatars

# Base URL for certificate sharing (public-facing URL)
BASE_URL=https://localhost

# Frontend (Vite — baked at build time)
VITE_API_URL=https://localhost
